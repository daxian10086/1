<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5DC"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- 标题区域 -->
        <LinearLayout
            android:id="@+id/layoutTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical">

            <!-- 标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="大仙算卦"
                android:textColor="#8B4513"
                android:textSize="32sp"
                android:textStyle="bold" />

            <!-- 提示文字 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="默念所想之事，心诚则灵"
                android:textColor="#666"
                android:textSize="16sp" />

        </LinearLayout>

        <!-- 摇卦动画区域 -->
        <FrameLayout
            android:id="@+id/layoutShaking"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="32dp">

            <!-- 摇桶图片 -->
            <ImageView
                android:id="@+id/ivShaking"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_shaking"
                android:visibility="gone" />

            <!-- 掉出的签 -->
            <ImageView
                android:id="@+id/ivStickOut"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_stick_out"
                android:visibility="gone" />

        </FrameLayout>

        <TextView
            android:id="@+id/tvShaking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="摇卦中..."
            android:textColor="#8B4513"
            android:textSize="24sp"
            android:textStyle="bold"
            android:visibility="gone" />

        <!-- 算卦按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnCastHexagram"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginHorizontal="32dp"
            android:backgroundTint="#8B4513"
            android:padding="16dp"
            android:text="算一卦"
            android:textSize="20sp"
            app:cornerRadius="8dp" />

        <!-- 卦象显示区域 -->
        <androidx.cardview.widget.CardView
            android:id="@+id/cardResult"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- 卦序和卦名 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvHexagramNumber"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="第1卦"
                        android:textColor="#8B4513"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvHexagramName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="乾"
                        android:textColor="#8B4513"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvSelectedLineName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="·初爻"
                        android:textColor="#FF6B6B"
                        android:textSize="20sp"
                        android:textStyle="bold" />

                </LinearLayout>

                <!-- 上下卦显示 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="上卦"
                        android:textColor="#666"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvUpperTrigram"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="☰ 乾（天）"
                        android:textColor="#333"
                        android:textSize="24sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="下卦"
                        android:textColor="#666"
                        android:textSize="14sp" />

                    <TextView
                        android:id="@+id/tvLowerTrigram"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="☰ 乾（天）"
                        android:textColor="#333"
                        android:textSize="24sp" />

                </LinearLayout>

                <!-- 整体卦象含义 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="卦象含义"
                    android:textColor="#666"
                    android:textSize="14sp" />

                <TextView
                    android:id="@+id/tvOverallMeaning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:lineSpacingExtra="4dp"
                    android:text="乾为天，象征刚健、进取、领导、创造。"
                    android:textColor="#333"
                    android:textSize="16sp" />

                <!-- 六爻显示 -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="六爻详解"
                    android:textColor="#666"
                    android:textSize="14sp" />

                <LinearLayout
                    android:id="@+id/layoutLines"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical" />

                <!-- 多维度运势解读 -->
                <TextView
                    android:id="@+id/tvFortuneAnalysis"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="#F0F8FF"
                    android:lineSpacingExtra="3dp"
                    android:padding="16dp"
                    android:textColor="#333"
                    android:textSize="14sp"
                    android:visibility="gone" />

                <!-- 选中的爻 -->
                <TextView
                    android:id="@+id/tvSelectedLine"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:background="#FFEB3B"
                    android:lineSpacingExtra="4dp"
                    android:padding="16dp"
                    android:textColor="#8B4513"
                    android:textSize="16sp"
                    android:visibility="gone" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
